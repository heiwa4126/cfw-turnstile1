{
	"name": "cfw-turnstile1",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"pre-deploy": "node --env-file .env.production scripts/inject-sitekey.mjs",
		"deploy-main": "wrangler deploy --env-file .env.production",
		"post-deploy": "node --env-file .env.production scripts/inject-sitekey.mjs -r",
		"deploy": "run-s pre-deploy deploy-main post-deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"format": "oxfmt",
		"lint": "oxlint",
		"check": "oxfmt && oxlint --fix"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.19",
		"@types/node": "^26.0.0",
		"npm-run-all2": "^9.0.2",
		"typescript": "^6.0.3",
		"vitest": "~4.1.9",
		"wrangler": "^4.104.0"
	}
}
